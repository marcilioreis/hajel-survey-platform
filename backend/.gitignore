# Dependências
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Variáveis de ambiente (contém senhas e secrets)
.env
.env.*
!.env.example

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Build e compilação TypeScript
dist/
build/
*.tsbuildinfo

# Arquivos de sistema operacional
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Diretório do Drizzle Kit (migrações e metadados gerados)
drizzle/
# Se você versiona migrações, pode querer incluir a pasta, mas geralmente é boa prática versionar
# Descomente a linha abaixo se quiser versionar as migrações:
!drizzle/migrations

# Arquivos de cache do ts-node-dev
.cache/
*.tsbuildinfo

# Configurações de IDE
.vscode/
.idea/
*.iml

# Arquivos de teste e cobertura
coverage/
.nyc_output/

# Arquivos temporários do sistema
tmp/
temp/