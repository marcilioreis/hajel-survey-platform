{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "types": [
      "node"
    ],
    "outDir": "./dist",
    "rootDir": "./", // ./src
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*",
    "drizzle.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}