{
    "backend/src/**/*.ts": [
        "cd backend && npm run lint:fix",
        "cd backend && npm run format"
    ],
    "frontend/src/**/*.{ts,tsx,js,jsx}": [
        "cd frontend && npm run lint:fix",
        "cd frontend && npm run format"
    ],
    "tests/**/*.ts": [
        "cd tests && npm run lint:fix",
        "cd tests && npm run format"
    ]
}